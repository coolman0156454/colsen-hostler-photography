# Core app
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_32_plus_char_random_string
NEXTAUTH_DEBUG=false
REQUEST_COUNTRY_ALLOWLIST=US
REQUEST_ALERT_THRESHOLD=100

# Google OAuth (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAILS=you@example.com

# Google Drive API access
# Use API key for public folders OR service account for private/shared drives.
GOOGLE_DRIVE_API_KEY=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_IMPERSONATE_USER=

# Initial folder mapping for auto-seeded galleries
DRIVE_FOLDER_FEATURED=
DRIVE_FOLDER_SPORTS=
DRIVE_FOLDER_PORTRAITS=
DRIVE_FOLDER_EVENTS=

# Password gallery token signing
GALLERY_ACCESS_TOKEN_SECRET=replace_with_random_string

# Contact form email (Resend)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Colsen Hostler Photography <onboarding@resend.dev>
CONTACT_TO_EMAIL=
